# MediOptima Database Configuration
# Copy this file to .env and fill in your actual database credentials

# Database Type: mysql or postgresql
DB_TYPE=mysql

# Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_db
DB_USER=root
DB_PASSWORD=your_secure_password

# Alternative PostgreSQL Configuration:
# DB_TYPE=postgresql
# DB_PORT=5432
# DB_USER=postgres
